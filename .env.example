# Copy to .env and fill in real values. .env is gitignored.

# --- MySQL source (basket-craft) ---
MYSQL_HOST=db.isba.co
MYSQL_PORT=3306
MYSQL_DB=basket_craft
MYSQL_USER=student
MYSQL_PASSWORD=

# --- PostgreSQL destination (AWS RDS or local Docker) ---
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=basket_craft
POSTGRES_USER=student
POSTGRES_PASSWORD=

# --- football-data.org v4 API ---
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_COMPETITION=PL
FOOTBALL_DATA_SEASON=2024

# --- Snowflake destination (soccer recruitment) ---
# ACCOUNT format: <orgname>-<account_name>  (e.g. ABCDEF-XY12345). Find it in Snowsight URL.
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_ROLE=ACCOUNTADMIN
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_DATABASE=SOCCER_RECRUITMENT
SNOWFLAKE_SCHEMA=RAW

# --- Firecrawl (web scraping) ---
FIRECRAWL_API_KEY=
